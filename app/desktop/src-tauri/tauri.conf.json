{
  "$schema": "https://schema.tauri.app/config/2",
  "productName": "TapChat Desktop",
  "version": "0.1.0",
  "identifier": "chat.tapchat.desktop",
  "build": {
    "frontendDist": "../dist",
    "devUrl": "http://localhost:1420",
    "beforeDevCommand": "npm run dev",
    "beforeBuildCommand": "npm run build"
  },
  "app": {
    "windows": [
      {
        "title": "TapChat Desktop",
        "width": 1360,
        "height": 920,
        "minWidth": 980,
        "minHeight": 760,
        "resizable": true
      }
    ],
    "security": {
      "csp": null
    }
  },
  "bundle": {
    "active": false
  }
}
